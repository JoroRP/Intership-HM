{% extends 'base.html.twig' %}

{% block title %}Order Management{% endblock %}

{% block body %}
    <div class="container py-5 px-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Orders</h1>
            <button class="btn btn-success" data-bs-toggle="collapse" href="#orderFormWrapper" role="button"
                    aria-expanded="false" aria-controls="orderFormWrapper">Add New Order
            </button>
        </div>

        <div id="flashMessages"></div>

        <div class="table-responsive">
            <table class="table table-striped">
                <thead class="table-dark">
                <tr>
                    <th>Order Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Customer</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody id="orderTableBody">

                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4">
            <button id="prevPageBtn" class="btn btn-secondary">Previous</button>
            <span id="paginationInfo"></span>
            <button id="nextPageBtn" class="btn btn-secondary">Next</button>
        </div>

        <div class="collapse mt-5" id="orderFormWrapper">
            <div class="card card-body shadow-sm">
                <h2 id="formTitle" class="mb-4">Add New Order</h2>
                <form id="orderForm">
                    <div class="mb-3">
                        <label for="total" class="form-label"><strong>Total:</strong></label>
                        <input type="text" class="form-control" id="total" name="total" placeholder="Enter order total"
                               required>
                    </div>
                    <div class="mb-3">
                        <label for="status" class="form-label"><strong>Status:</strong></label>
                        <select class="form-select" id="status" name="status">
                            <option value="Pending">Pending</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="customer" class="form-label"><strong>Select Customer:</strong></label>
                        <select class="form-select" id="customer" name="customer" required>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Submit</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        let currentPage = 1;
        const limit = 5;

        document.addEventListener('DOMContentLoaded', () => {
            fetchOrders();
            fetchCustomers();
        });

        function fetchCustomers() {
            fetch('/api/customers')
                .then(response => response.json())
                .then(data => {
                    const customerDropdown = document.getElementById('customer');
                    customerDropdown.innerHTML = '';

                    data.customers.forEach(customer => {
                        const option = document.createElement('option');
                        option.value = customer.id;
                        option.textContent = customer.name;
                        customerDropdown.appendChild(option);
                    });
                })
                .catch(error => console.error('Error fetching customers:', error));
        }


        function fetchOrders() {
            fetch(`/api/orders?page=${currentPage}&limit=${limit}`)
                .then(response => response.json())
                .then(data => {
                    const tableBody = document.getElementById('orderTableBody');
                    const paginationInfo = document.getElementById('paginationInfo');
                    tableBody.innerHTML = '';

                    data.orders.forEach(order => {
                        const orderDate = new Date(order.order_date.date).toLocaleDateString();

                        const customerName = order.customer_name ? order.customer_name : 'N/A';

                        const row = `<tr id="row-${order.id}">
                    <td id="order_date-${order.id}">${orderDate}</td>
                    <td id="total-${order.id}">${order.total}</td>
                    <td id="status-${order.id}">${order.status}</td>
                    <td id="customer-${order.id}">${customerName}</td>
                    <td class="w-25">
                        <button class="btn btn-warning btn-sm" onclick="editOrder(${order.id})">Edit</button>
                        <button class="btn btn-success btn-sm d-none" id="save-btn-${order.id}" onclick="saveOrder(${order.id})">Save</button>
                        <button class="btn btn-danger btn-sm" onclick="deleteOrder(${order.id})">Delete</button>
                    </td>
                </tr>`;
                        tableBody.innerHTML += row;
                    });

                    paginationInfo.textContent = `Page ${data.page} of ${data.totalPages}`;
                    document.getElementById('prevPageBtn').disabled = data.page <= 1;
                    document.getElementById('nextPageBtn').disabled = data.page >= data.totalPages;
                });
        }


        document.getElementById('orderForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const total = document.getElementById('total').value;
            const status = document.getElementById('status').value;
            const customer_id = document.getElementById('customer').value;

            fetch('/api/orders/', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({total, status, customer_id})
            })
                .then(response => response.json())
                .then(data => {
                    if (data.error) {
                        showAlert('danger', data.error);
                    } else {
                        showAlert('success', data.success);
                        fetchOrders();
                        document.getElementById('orderForm').reset();
                        document.getElementById('orderFormWrapper').classList.remove('show');
                    }
                });
        });


        function editOrder(id) {
            const totalElement = document.getElementById(`total-${id}`);
            const statusElement = document.getElementById(`status-${id}`);
            const customerElement = document.getElementById(`customer-${id}`);
            const editButton = document.querySelector(`#row-${id} .btn-warning`);
            const saveButton = document.getElementById(`save-btn-${id}`);

            totalElement.innerHTML = `<input type="text" class="form-control" value="${totalElement.textContent}" id="edit-total-${id}">`;
            statusElement.innerHTML = `<select class="form-select" id="edit-status-${id}">
                <option value="Pending" ${statusElement.textContent === 'Pending' ? 'selected' : ''}>Pending</option>
                <option value="Completed" ${statusElement.textContent === 'Completed' ? 'selected' : ''}>Completed</option>
                <option value="Cancelled" ${statusElement.textContent === 'Cancelled' ? 'selected' : ''}>Cancelled</option>
            </select>`;
            customerElement.innerHTML = `<input type="text" class="form-control" value="${customerElement.textContent}" id="edit-customer-${id}">`;

            editButton.classList.add('d-none');
            saveButton.classList.remove('d-none');
        }

        function saveOrder(id) {
            const updatedTotal = document.getElementById(`edit-total-${id}`).value;
            const updatedStatus = document.getElementById(`edit-status-${id}`).value;
            const updatedCustomer = document.getElementById(`edit-customer-${id}`).value;

            fetch(`/api/orders/${id}`, {
                method: 'PUT',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    total: updatedTotal,
                    status: updatedStatus,
                    customer_id: updatedCustomer
                })
            })
                .then(response => response.json())
                .then(data => {
                    if (data.error) {
                        showAlert('danger', data.error);
                    } else {
                        showAlert('success', data.success);
                        fetchOrders();
                    }
                });
        }

        function deleteOrder(id) {
            if (!confirm('Are you sure you want to delete this order?')) return;

            fetch(`/api/orders/${id}`, {
                method: 'DELETE'
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showAlert('success', data.success);
                        fetchOrders();
                    }
                });
        }

        function showAlert(type, message) {
            const flashMessages = document.getElementById('flashMessages');
            flashMessages.innerHTML = `<div class="alert alert-${type}">${message}</div>`;
            setTimeout(() => flashMessages.innerHTML = '', 3000);
        }

        document.getElementById('prevPageBtn').addEventListener('click', function () {
            currentPage--;
            fetchOrders();
        });

        document.getElementById('nextPageBtn').addEventListener('click', function () {
            currentPage++;
            fetchOrders();
        });
    </script>
{% endblock %}
