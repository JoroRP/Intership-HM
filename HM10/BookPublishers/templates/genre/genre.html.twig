{% extends 'base.html.twig' %}

{% block title %}Genres - Book Publishing{% endblock %}

{% block body %}
    <div class="container py-5 px-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Available Genres</h1>

            <a href="{{ path('genre_new') }}" class="btn btn-success">Add New Genre</a>
        </div>

        <form method="post">
            <div class="form-group mb-3">
                <label for="genre" class="form-label"><strong>Select a Genre:</strong></label>
                <select id="genre" name="genre" class="form-select" onchange="this.form.submit()">
                    <option value="">-- Select a Genre --</option>
                    {% for genre in genres %}
                        <option value="{{ genre.id }}"
                                {% if selectedGenre and genre.id == selectedGenre.id %}selected{% endif %}>
                            {{ genre.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
        </form>

        {% if selectedGenre %}
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h3 class="card-title">{{ selectedGenre.name }}</h3>
                    <p>{{ selectedGenre.description }}</p>
                    <hr>

                    <h5>Books in this Genre:</h5>
                    {% if selectedGenre.books is not empty %}
                        <ul class="list-group mb-3">
                            {% for book in selectedGenre.books %}
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <a href="{{ path('book_show', {id: book.id}) }}" class="text-decoration-none">
                                        {{ book.title }}
                                    </a>
                                    <span class="badge bg-primary">Published: {{ book.publicationYear }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <div class="alert alert-warning mt-3">No books found for this genre.</div>
                    {% endif %}

                    <div class="mt-4 d-flex justify-content-end mt-3">
                        <a href="{{ path('genre_edit', {id: selectedGenre.id}) }}" class="btn btn-warning me-2">Edit</a>

                        <form method="post" action="{{ path('genre_delete', {id: selectedGenre.id}) }}"
                              onsubmit="return confirm('Are you sure you want to delete this genre?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ selectedGenre.id) }}">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="alert alert-info text-center">Please select a genre to view its details.</div>
        {% endif %}
    </div>
{% endblock %}
