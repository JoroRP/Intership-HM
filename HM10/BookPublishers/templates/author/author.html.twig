{% extends 'base.html.twig' %}

{% block title %}Select Author - Book Publishing{% endblock %}

{% block body %}
    <div class="container py-5 px-5">
        <div class="row">
            <div>
                <h1 class="mb-4 text-center">Select an Author</h1>

                <form method="post" class="mb-4">
                    <div class="form-group mb-3">
                        <label for="author" class="form-label"><strong>Choose an Author:</strong></label>
                        <select id="author" name="author" class="form-select" onchange="this.form.submit()">
                            <option value="">-- Select an Author --</option>
                            {% for author in authors %}
                                <option value="{{ author.id }}"
                                        {% if selectedAuthor and author.id == selectedAuthor.id %}selected{% endif %}>
                                    {{ author.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </form>

                {% if selectedAuthor %}
                    <div class="card shadow-sm mb-4">
                        <div class="card-body">
                            <h3 class="card-title">{{ selectedAuthor.name }}</h3>
                            <p><strong>Birth Year:</strong> {{ selectedAuthor.birthYear }}</p>
                            <p><strong>Nationality:</strong> {{ selectedAuthor.nationality }}</p>
                            <hr>

                            <h5 class="mb-3">Books Written by {{ selectedAuthor.name }}:</h5>

                            {% if selectedAuthor.books is not empty %}
                                <ul class="list-group">
                                    {% for book in selectedAuthor.books %}
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <a href="{{ path('book_show', {id: book.id}) }}"
                                               class="text-decoration-none">
                                                {{ book.title }}
                                            </a>
                                            <span class="badge bg-primary rounded-pill">Published: {{ book.publicationYear }}</span>
                                        </li>
                                    {% endfor %}
                                </ul>
                            {% else %}
                                <div class="alert alert-warning mt-3" role="alert">
                                    No books found for this author.
                                </div>
                            {% endif %}

                            <div class="mt-4 d-flex justify-content-end mt-3">
                                <a href="{{ path('author_edit', {id: selectedAuthor.id}) }}"
                                   class="btn btn-warning me-2">
                                    Edit Author
                                </a>

                                <form method="post" action="{{ path('author_delete', {id: selectedAuthor.id}) }}"
                                      onsubmit="return confirm('Are you sure you want to delete this author?');">
                                    <input type="hidden" name="_token"
                                           value="{{ csrf_token('delete' ~ selectedAuthor.id) }}">
                                    <button class="btn btn-danger">Delete Author</button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-info text-center" role="alert">
                        Please select an author to view their details.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
