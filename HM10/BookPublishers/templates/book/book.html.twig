{% extends 'base.html.twig' %}

{% block title %}Books - Book Publishing{% endblock %}

{% block body %}
    <div class="container py-5 px-5">

        <div class="row mb-4">
            <div class="col-md-12">
                <form method="get" action="{{ path('book_index') }}" class="d-flex px-5">
                    <input class="form-control me-2" type="search" name="search" placeholder="Search by title"
                           value="{{ searchTerm }}" aria-label="Search">
                    <button class="btn btn-outline-success" type="submit">Search</button>
                </form>
            </div>
        </div>

        <div class="row">
            {% for book in books %}
                <div class="col-md-3 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{ book.title }}</h5>
                            <p class="card-text">
                                Author: {{ book.author.name }}<br>
                                Published: {{ book.publicationYear }}<br>
                                Genres:
                                {% for genre in book.genre %}
                                    {{ genre.name }}{% if not loop.last %}, {% endif %}
                                {% endfor %}
                            </p>
                        </div>

                        <div class="card-footer d-flex">
                            <div class="btn btn-sm">
                                <a href="{{ path('book_show', {id: book.id}) }}"
                                   class="btn btn-primary">View Details</a>

                                <a href="{{ path('book_edit', {id: book.id}) }}" class="btn btn-warning mx-1">Edit</a>

                            </div>

                        </div>

                    </div>
                </div>
            {% else %}
                <p>No books found.</p>
            {% endfor %}
        </div>
    </div>
{% endblock %}
