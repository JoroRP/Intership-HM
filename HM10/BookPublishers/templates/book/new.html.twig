{% extends 'base.html.twig' %}

{% block title %}Create New Book{% endblock %}

{% block body %}
    <div class="container py-5 px-5">
        <h1 class="mb-4 text-center">Create a New Book</h1>

        {{ form_start(form) }}
        <div class="mb-3">
            {{ form_label(form.title, 'Title', {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.title, {'attr': {'class': 'form-control' ~ (form.title.vars.valid ? '' : ' is-invalid')}}) }}
            {% if form.title.vars.errors %}
                <div class="invalid-feedback d-block mt-2">
                    {{ form_errors(form.title) }}
                </div>
            {% endif %}
        </div>

        <div class="mb-3">
            {{ form_label(form.isbn, 'ISBN', {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.isbn, {'attr': {'class': 'form-control' ~ (form.isbn.vars.valid ? '' : ' is-invalid')}}) }}
            {% if form.isbn.vars.errors %}
                <div class="invalid-feedback d-block mt-2">
                    {{ form_errors(form.isbn) }}
                </div>
            {% endif %}
        </div>

        <div class="mb-3">
            {{ form_label(form.publicationYear, 'Publication Year', {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.publicationYear, {'attr': {'class': 'form-control' ~ (form.publicationYear.vars.valid ? '' : ' is-invalid')}}) }}
            {% if form.publicationYear.vars.errors %}
                <div class="invalid-feedback d-block mt-2">
                    {{ form_errors(form.publicationYear) }}
                </div>
            {% endif %}
        </div>

        <div class="mb-3">
            {{ form_label(form.author, 'Author', {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.author, {'attr': {'class': 'form-control' ~ (form.author.vars.valid ? '' : ' is-invalid')}}) }}
            {% if form.author.vars.errors %}
                <div class="invalid-feedback d-block mt-2">
                    {{ form_errors(form.author) }}
                </div>
            {% endif %}
        </div>

        <div class="mb-3">
            {{ form_label(form.genre, 'Genres', {'label_attr': {'class': 'form-label fw-bold'}}) }}

            <div class="form-group">
                {% for child in form.genre %}
                    <div class="form-check form-check-inline">
                        {{ form_widget(child, {'attr': {'class': 'form-check-input' ~ (child.vars.valid ? '' : ' is-invalid')}}) }}
                        {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                    </div>
                {% endfor %}
            </div>

            {% if form.genre.vars.errors %}
                <div class="invalid-feedback d-block mt-2">
                    {{ form_errors(form.genre) }}
                </div>
            {% endif %}
        </div>

        <button type="submit" class="btn btn-primary">Create Book</button>
        {{ form_end(form) }}
    </div>
{% endblock %}
