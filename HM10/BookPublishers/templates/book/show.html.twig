{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} - Details{% endblock %}

{% block body %}
    <div class="container py-5 px-5">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="card mb-3">

                    <div class="card-header bg-primary text-white">
                        <h2 class="card-title mb-0">{{ book.title }}</h2>
                    </div>

                    <div class="card-body">
                        <h5 class="card-subtitle mb-3 text-muted">Book Details</h5>

                        <p class="mb-2">
                            <strong>Author:</strong> {{ book.author.name }}
                        </p>

                        <p class="mb-2">
                            <strong>Published Year:</strong> {{ book.publicationYear }}
                        </p>

                        <p class="mb-2">
                            <strong>ISBN:</strong> {{ book.isbn }}
                        </p>

                        <p class="mb-4">
                            <strong>Genres:</strong>
                            {% for genre in book.genre %}
                                <span class="badge bg-success">{{ genre.name }}</span>
                            {% endfor %}
                        </p>

                        <a href="{{ path('book_index') }}" class="btn btn-secondary mb-2">Back to Book List</a>
                        <form method="post"
                              action="{{ path('book_delete', {id: book.id}) }}"
                              onsubmit="return confirm('Are you sure you want to delete this book?');">

                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                            <button class="btn btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
