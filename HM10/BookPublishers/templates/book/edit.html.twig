{% extends 'base.html.twig' %}

{% block title %}Edit Book: {{ book.title }}{% endblock %}

{% block body %}
    <div class="container py-5 px-5">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <h1 class="mb-4">Edit Book: {{ book.title }}</h1>

                <div class="card">
                    <div class="card-body">
                        {{ form_start(form) }}

                        <div class="mb-3">
                            {{ form_label(form.title, 'Title', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.title) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.isbn, 'ISBN', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.isbn, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.isbn) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.publicationYear, 'Publication Year', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.publicationYear, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.publicationYear) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.author, 'Author', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.author, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.author) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.genre, 'Genres', {'label_attr': {'class': 'form-label'}}) }}
                            <div class="form-group">
                                {% for child in form.genre %}
                                    <div class="form-check">
                                        {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                {% endfor %}
                            </div>
                            {{ form_errors(form.genre) }}
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-success">Save Changes</button>
                            <a href="{{ path('book_index') }}" class="btn btn-secondary">Cancel</a>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
