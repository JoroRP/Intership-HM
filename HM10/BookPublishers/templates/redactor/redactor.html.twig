{% extends 'base.html.twig' %}

{% block title %}Redactors - Book Publishing{% endblock %}

{% block body %}
    <div class="container py-5 px-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Available Redactors</h1>

            <a href="{{ path('redactor_new') }}" class="btn btn-success">Add New Redactor</a>
        </div>

        <form method="post">
            <div class="form-group mb-3">
                <label for="redactor" class="form-label"><strong>Select a Redactor:</strong></label>
                <select id="redactor" name="redactor" class="form-select" onchange="this.form.submit()">
                    <option value="">-- Select a Redactor --</option>
                    {% for redactor in redactors %}
                        <option value="{{ redactor.id }}"
                                {% if selectedRedactor and redactor.id == selectedRedactor.id %}selected{% endif %}>
                            {{ redactor.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
        </form>

        {% if selectedRedactor %}
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h3 class="card-title">{{ selectedRedactor.name }}</h3>
                    <p><strong>Specialty:</strong> {{ selectedRedactor.specialty }}</p>
                    <p><strong>Redactor ID:</strong> {{ selectedRedactor.uniqueID }}</p>
                    <hr>

                    <h5>Books Edited by {{ selectedRedactor.name }}:</h5>

                    {% if selectedRedactor.books is not empty %}
                        <ul class="list-group mb-3">
                            {% for book in selectedRedactor.books %}
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <a href="{{ path('book_show', {id: book.id}) }}" class="text-decoration-none">
                                        {{ book.title }}
                                    </a>
                                    <span class="badge bg-primary">Published: {{ book.publicationYear }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <div class="alert alert-warning mt-3">No books found for this redactor.</div>
                    {% endif %}

                    <div class="d-flex justify-content-end mt-4">
                        <a href="{{ path('redactor_edit', {id: selectedRedactor.id}) }}" class="btn btn-warning me-2">Edit</a>

                        <form method="post" action="{{ path('redactor_delete', {id: selectedRedactor.id}) }}"
                              onsubmit="return confirm('Are you sure you want to delete this redactor?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ selectedRedactor.id) }}">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="alert alert-info text-center">Please select a redactor to view their details.</div>
        {% endif %}
    </div>
{% endblock %}
