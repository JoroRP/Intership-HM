{% extends 'base.html.twig' %}

{% block title %}Edit Redactor{% endblock %}

{% block body %}
    <div class="container py-5">
        <h1 class="mb-4">Edit Redactor</h1>

        {{ form_start(form) }}

        <div class="mb-3">
            {{ form_label(form.name, 'Name', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.name) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.uniqueID, 'Unique ID', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.uniqueID, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.uniqueID) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.specialty, 'Specialty', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.specialty, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.specialty) }}
        </div>

        <button type="submit" class="btn btn-success">Save Changes</button>
        <a href="{{ path('redactor_index') }}" class="btn btn-secondary">Cancel</a>

        {{ form_end(form) }}
    </div>
{% endblock %}
